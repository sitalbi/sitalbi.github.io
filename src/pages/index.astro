---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Simon Talbi" description="Portfolio website">
  <h1>Hi, I'm Simon Talbi</h1>
  <h2 class="muted">Game and Engine Programmer</h2>

  <p>
    I am a french game programmer, currently working in Japan. This website
    presents a selection of personal projects related to game
    programming, rendering, and engine development.
  </p>

  <h2>About</h2>

  <p>
    My professional background includes AA and AAA game programming, engine development and
    R&D works on game related projects. I also enjoy learning and experimenting
    in my free time on various subjects through personal projects.
  </p>

  <p>
    My main interests are game systems, engine programming, rendering
    technology, and technical architecture.
  </p>

  <h2>Some of my projects</h2>

  <div class="projects-grid">
    {
      projects.slice(0, 2).map((project) => (
        <article class="project-card">
          <h3 class="project-card-title">
            <a href={project.url}>{project.title}</a>
          </h3>

          <a href={project.url} class="project-image-link">
            <img
              src={project.image}
              alt={project.title}
              class="project-image"
            />
          </a>

          <p class="project-card-description">{project.description}</p>
        </article>
      ))
    }
  </div>

  <div class="projects-more">
    <a href="/projects" class="see-more-button">View all projects →</a>
  </div>

  <h2>Links</h2>

  <div class="social-links">
    <a
      href="mailto:simon.talbi0111@gmail.com"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        src="data:image/svg+xml;base64,"
        alt="Mail"
      />
    </a>

    <a
      href="https://github.com/sitalbi"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        src="data:image/svg+xml;base64,"
        alt="GitHub"
      />
    </a>

    <a
      href="https://www.linkedin.com/in/simon-talbi/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        src="data:image/svg+xml;base64,"
        alt="LinkedIn"
      />
    </a>
  </div>
</BaseLayout>
